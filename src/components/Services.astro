---
import { services } from '../data/services';

// The homepage copy uses the source document's exact H3 headings, which differ
// from the nav labels for two items.
const headingOverride: Record<string, string> = {
  'emergency-electricians': 'Emergency Electrician',
  'house-rewiring': 'Home Rewiring',
};
---
<section id="services" class="relative bg-brand-bg py-24">
  <div class="pointer-events-none absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(90deg, var(--color-brand-secondary) 1px, transparent 1px); background-size: 60px 60px;"></div>
  <div class="relative mx-auto max-w-7xl px-5 sm:px-8 lg:px-8">
    <div class="reveal mb-4 max-w-3xl">
      <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
        <span class="inline-block h-px w-10 bg-brand-accent"></span>
        Electrical services
      </p>
      <h2 class="font-heading text-[clamp(1.9rem,4.5vw,3rem)] font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text">
        Electrical services we offer <span class="text-brand-secondary">across St Ives homes</span>
      </h2>
    </div>
    <p class="reveal mb-12 max-w-2xl font-body text-lg leading-relaxed text-brand-muted">
      From urgent repairs to full upgrades, our electrician team based in St Ives covers every job below:
    </p>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s, i) => (
        <a href={`/services/${s.slug}`} class="svc reveal group relative flex flex-col overflow-hidden border border-white/5 bg-brand-surface transition-colors hover:border-brand-accent/50" style={`transition-delay: ${(i % 3) * 70}ms; clip-path: polygon(0 0, 100% 0, 100% 94%, 96% 100%, 0 100%);`}>
          <span class="svc-top absolute inset-x-0 top-0 z-20 h-1 origin-left scale-x-0 bg-brand-accent transition-transform duration-300"></span>
          <div class="relative h-40 overflow-hidden">
            <img src={s.img} alt={s.alt} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-surface via-brand-surface/20 to-transparent"></div>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h3 class="font-heading text-lg font-black uppercase leading-tight tracking-tight text-brand-secondary">{headingOverride[s.slug] ?? s.navLabel}</h3>
            <p class="mt-2 font-body text-sm leading-relaxed text-brand-muted">{s.blurb}</p>
            <span class="mt-4 inline-flex items-center gap-1 font-heading text-xs font-bold uppercase tracking-widest text-brand-accent transition-colors group-hover:text-brand-secondary">Learn more →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .svc:hover .svc-top { transform: scaleX(1); }
</style>
