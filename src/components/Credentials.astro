---
import Bolt from './Bolt.astro';
---
<section id="credentials" class="relative overflow-hidden py-20" style="background: linear-gradient(110deg, var(--color-brand-secondary) 0%, var(--color-brand-accent) 100%);">
  <div class="pointer-events-none absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(-45deg, #000 0 2px, transparent 2px 22px);"></div>
  <div class="relative mx-auto max-w-7xl px-5 sm:px-8 lg:px-8">
    <div class="reveal mb-8 max-w-3xl">
      <p class="mb-3 font-body text-xs font-bold uppercase tracking-[0.3em] text-brand-bg/70">Compliance and credentials</p>
      <h2 class="font-heading text-[clamp(1.7rem,4vw,2.6rem)] font-black uppercase leading-tight tracking-tight text-brand-bg">
        Compliance and credentials you can verify
      </h2>
      <p class="mt-4 font-body text-base leading-relaxed text-brand-bg/80">
        Every job for Powerhub Electrical in St Ives is backed by real, checkable credentials:
      </p>
    </div>
    <ul class="grid gap-px overflow-hidden border border-brand-bg/20 bg-brand-bg/20 sm:grid-cols-2">
      <li class="reveal flex items-start gap-3 bg-brand-bg p-6">
        <span class="mt-0.5 grid h-8 w-8 shrink-0 place-items-center text-brand-bg" style="clip-path: polygon(0 0, 100% 0, 100% 70%, 70% 100%, 0 100%); background: var(--color-brand-accent);">
          <Bolt class="h-4 w-4" />
        </span>
        <span class="font-body text-base leading-relaxed text-brand-text">
          Licensed electrical contractor, NSW Licence #467291C, verifiable directly through the <a href="https://verify.licence.nsw.gov.au/details/Contractor%20Licence/1-46C84T5" target="_blank" rel="noopener noreferrer" class="font-semibold text-brand-secondary underline decoration-brand-accent/50 underline-offset-4 hover:text-brand-accent">NSW Government verification register</a>
        </span>
      </li>
      <li class="reveal flex items-start gap-3 bg-brand-bg p-6" style="transition-delay: 80ms;">
        <span class="mt-0.5 grid h-8 w-8 shrink-0 place-items-center text-brand-bg" style="clip-path: polygon(0 0, 100% 0, 100% 70%, 70% 100%, 0 100%); background: var(--color-brand-accent);">
          <Bolt class="h-4 w-4" />
        </span>
        <span class="font-body text-base leading-relaxed text-brand-text">
          <a href="https://abr.business.gov.au/ABN/View?id=91677354602" target="_blank" rel="noopener noreferrer" class="font-semibold text-brand-secondary underline decoration-brand-accent/50 underline-offset-4 hover:text-brand-accent">ABN 91 677 354 602</a>, registered and publicly searchable
        </span>
      </li>
    </ul>
  </div>
</section>
