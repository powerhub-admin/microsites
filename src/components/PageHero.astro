---
import Bolt from './Bolt.astro';

interface Crumb { label: string; href?: string }
interface Props {
  eyebrow: string;
  title: string;
  accent?: string;   // appended, rendered in the brand highlight colour
  sub?: string;
  crumbs?: Crumb[];
  img?: string;
  badges?: string[];
}
const { eyebrow, title, accent, sub, crumbs = [], img = '/images/powerhub/home/blueprint.webp', badges } = Astro.props;
---
<section class="relative overflow-hidden bg-brand-bg pt-32 pb-20 sm:pt-40 sm:pb-24">
  <div class="pointer-events-none absolute inset-0 opacity-[0.06]" style="background-image: linear-gradient(var(--color-brand-secondary) 1px, transparent 1px), linear-gradient(90deg, var(--color-brand-secondary) 1px, transparent 1px); background-size: 48px 48px;"></div>
  <img src={img} alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover opacity-15" />
  <div class="absolute inset-0" style="background: linear-gradient(to right, var(--color-brand-bg) 40%, transparent 100%);"></div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
    {crumbs.length > 0 && (
      <nav aria-label="Breadcrumb" class="reveal mb-6 font-body text-sm text-brand-muted">
        <ol class="flex flex-wrap items-center gap-2">
          {crumbs.map((c, i) => (
            <>
              {c.href ? (
                <li><a href={c.href} class="transition-colors hover:text-brand-secondary">{c.label}</a></li>
              ) : (
                <li class="text-brand-text">{c.label}</li>
              )}
              {i < crumbs.length - 1 && <li aria-hidden="true" class="text-brand-muted/40">/</li>}
            </>
          ))}
        </ol>
      </nav>
    )}
    <p class="reveal mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted" style="transition-delay:80ms;">
      <span class="inline-block h-px w-10 bg-brand-accent"></span> {eyebrow}
    </p>
    <h1 class="reveal font-heading text-4xl font-black uppercase leading-[1.02] tracking-[-0.02em] text-brand-text sm:text-5xl lg:text-6xl" style="transition-delay:160ms;">
      {title}{accent && <> <span class="text-brand-secondary">{accent}</span></>}
    </h1>
    {sub && (
      <p class="reveal mt-6 max-w-2xl font-body text-lg leading-relaxed text-brand-muted" style="transition-delay:240ms;">{sub}</p>
    )}
    {badges && (
      <div class="reveal mt-8 flex flex-wrap gap-3" style="transition-delay:320ms;">
        {badges.map((b) => (
          <span class="inline-flex items-center gap-2 border border-brand-secondary/30 bg-brand-surface/40 px-4 py-2 font-heading text-xs font-bold uppercase tracking-wide text-brand-text">
            <Bolt class="h-3 w-3 text-brand-accent" /> {b}
          </span>
        ))}
      </div>
    )}
    {Astro.slots.has('default') && (
      <div class="reveal mt-6 max-w-2xl space-y-4 font-body text-base leading-relaxed text-brand-muted sm:text-lg" style="transition-delay:360ms;">
        <slot />
      </div>
    )}
  </div>
</section>
