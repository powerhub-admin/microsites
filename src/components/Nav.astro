---
import Bolt from './Bolt.astro';
import OutlineButton from './OutlineButton.astro';
import { services } from '../data/services';
import { site, mainNav } from '../data/site';

interface Props { transparent?: boolean }
const { transparent = true } = Astro.props;
---
<header id="nsb-nav" class:list={["fixed inset-x-0 top-0 z-50 transition-all duration-300", !transparent && "bg-brand-bg/90 shadow-lg shadow-black/40 backdrop-blur-md"]}>
  <span data-accent class:list={["absolute inset-x-0 bottom-0 h-0.5 origin-left bg-gradient-to-r from-brand-secondary via-brand-accent to-brand-secondary transition-transform duration-500", transparent ? "scale-x-0" : "scale-x-100"]}></span>
  <nav class:list={["mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 transition-all duration-300 sm:px-8", transparent ? "py-5" : "py-3.5"]} data-navbar>
    <a href={site.home} class="flex items-center" aria-label="Powerhub Electrical home">
      <img src="/images/powerhub/logo.webp" alt="Powerhub Electrical" width="300" height="99" class="h-12 w-auto sm:h-14" />
    </a>

    <div class="hidden items-center gap-7 lg:flex">
      {mainNav.map((l) => (
        l.dropdown ? (
          <div class="nsb-drop group relative">
            <a href={l.href} class="group/link relative inline-flex items-center gap-1 font-body text-sm font-medium uppercase tracking-wide text-brand-muted transition-colors hover:text-brand-text">
              {l.label}
              <svg class="h-3 w-3 transition-transform duration-300 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              <span class="absolute -bottom-1.5 left-0 h-[2px] w-0 -skew-x-[30deg] bg-brand-accent transition-all duration-300 group-hover:w-full"></span>
            </a>
            <div class="nsb-drop-panel invisible absolute left-1/2 top-full -translate-x-1/2 pt-4 opacity-0 transition-all duration-200">
              <div class="w-[38rem] max-w-[90vw] border border-brand-secondary/25 bg-brand-surface p-4 shadow-2xl shadow-black/60" style="clip-path: polygon(0 0, 100% 0, 99% 100%, 0 100%);">
                <span class="absolute inset-x-0 top-0 h-0.5 bg-gradient-to-r from-brand-secondary via-brand-accent to-brand-secondary"></span>
                <div class="grid grid-cols-2 gap-x-4 gap-y-0.5">
                  {services.map((s) => (
                    <a href={`/services/${s.slug}`} class="group/item flex items-center gap-2.5 px-3 py-2 transition-colors hover:bg-brand-bg">
                      <span class="grid h-6 w-6 shrink-0 place-items-center bg-brand-accent/15 text-brand-accent transition-colors group-hover/item:bg-brand-accent group-hover/item:text-brand-bg" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0 100%);"><Bolt class="h-3 w-3" /></span>
                      <span class="font-body text-sm text-brand-muted transition-colors group-hover/item:text-brand-text">{s.navLabel}</span>
                    </a>
                  ))}
                </div>
                <a href="/services" class="mt-2 flex items-center justify-center gap-2 border-t border-white/10 pt-3 font-heading text-xs font-bold uppercase tracking-widest text-brand-secondary transition-colors hover:text-brand-accent">
                  View all services →
                </a>
              </div>
            </div>
          </div>
        ) : (
          <a href={l.href} class="group relative font-body text-sm font-medium uppercase tracking-wide text-brand-muted transition-colors hover:text-brand-text">
            {l.label}
            <span class="absolute -bottom-1.5 left-0 h-[2px] w-0 -skew-x-[30deg] bg-brand-accent transition-all duration-300 group-hover:w-full"></span>
          </a>
        )
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a href={site.phoneHref} class="hidden font-heading text-sm font-bold text-brand-secondary transition-colors hover:text-brand-text sm:inline">{site.phoneDisplay}</a>
      <a href="/contact-us" class="sweep-btn group relative hidden items-center gap-2 overflow-hidden px-4 py-2 font-heading text-sm font-bold text-brand-bg lg:inline-flex" style="clip-path: polygon(8% 0, 100% 0, 92% 100%, 0 100%); background: var(--color-brand-accent);">
        <span class="relative z-10">Book Now</span>
        <Bolt class="relative z-10 h-3.5 w-3.5" />
      </a>

      <OutlineButton href={site.phoneHref} label={`Call ${site.phoneDisplay}`} class="h-10 px-3 text-sm sm:hidden">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Call Now
      </OutlineButton>

      <button id="nsb-nav-toggle" type="button" aria-expanded="false" aria-controls="nsb-nav-mobile" aria-label="Toggle menu" class="relative grid h-10 w-10 shrink-0 place-items-center text-brand-text lg:hidden">
        <span class="relative block h-4 w-5" aria-hidden="true">
          <span class="nsb-bar absolute left-0 top-0 h-0.5 w-full bg-current transition-all duration-300"></span>
          <span class="nsb-bar absolute left-0 top-1.5 h-0.5 w-full bg-current transition-all duration-300"></span>
          <span class="nsb-bar absolute left-0 top-3 h-0.5 w-full bg-current transition-all duration-300"></span>
        </span>
      </button>
    </div>
  </nav>

  <div id="nsb-nav-mobile" class="invisible fixed inset-x-0 top-[64px] -z-10 max-h-0 overflow-hidden bg-brand-bg opacity-0 transition-all duration-300 lg:hidden" style="border-top: 1px solid rgba(255,154,0,0.15);">
    <div class="flex flex-col gap-1 px-5 pb-6 pt-4 sm:px-8">
      {mainNav.map((l) => (
        l.dropdown ? (
          <div class="border-b border-white/5">
            <button type="button" class="nsb-sub-toggle flex w-full items-center justify-between px-3 py-3 font-body text-base font-medium uppercase tracking-wide text-brand-muted transition-colors hover:text-brand-text" aria-expanded="false">
              {l.label}
              <svg class="nsb-sub-chevron h-4 w-4 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="nsb-sub-panel grid max-h-0 grid-cols-1 gap-0.5 overflow-hidden pl-3 transition-all duration-300 sm:grid-cols-2">
              {services.map((s) => (
                <a href={`/services/${s.slug}`} class="flex items-center gap-2 px-3 py-2 font-body text-sm text-brand-muted transition-colors hover:text-brand-secondary">
                  <Bolt class="h-3 w-3 text-brand-accent" /> {s.navLabel}
                </a>
              ))}
              <a href="/services" class="px-3 py-2 font-heading text-xs font-bold uppercase tracking-widest text-brand-secondary">View all services →</a>
            </div>
          </div>
        ) : (
          <a href={l.href} class="px-3 py-3 font-body text-base font-medium uppercase tracking-wide text-brand-muted transition-colors hover:text-brand-text">{l.label}</a>
        )
      ))}
      <a href={site.phoneHref} class="mt-2 px-3 py-3 font-heading text-base font-bold text-brand-secondary">{site.phoneDisplay}</a>
      <a href="/contact-us" class="sweep-btn group relative mt-3 inline-flex items-center justify-center gap-2 overflow-hidden px-4 py-3 font-heading text-sm font-bold text-brand-bg" style="clip-path: polygon(4% 0, 100% 0, 96% 100%, 0 100%); background: var(--color-brand-accent);">
        <span class="relative z-10">Book Now</span>
        <Bolt class="relative z-10 h-3.5 w-3.5" />
      </a>
    </div>
  </div>
</header>

<style>
  .nsb-drop:hover .nsb-drop-panel,
  .nsb-drop:focus-within .nsb-drop-panel { visibility: visible; opacity: 1; }

  #nsb-nav-mobile.is-open { visibility: visible; z-index: 40; max-height: calc(100vh - 64px); opacity: 1; overflow-y: auto; }
  .nsb-sub-panel.is-open { max-height: 40rem; }

  #nsb-nav-toggle[aria-expanded='true'] .nsb-bar:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  #nsb-nav-toggle[aria-expanded='true'] .nsb-bar:nth-child(2) { opacity: 0; }
  #nsb-nav-toggle[aria-expanded='true'] .nsb-bar:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
</style>

<script>
  const nav = document.getElementById('nsb-nav');
  const bar = nav?.querySelector('[data-navbar]') as HTMLElement | null;
  const accent = nav?.querySelector('[data-accent]') as HTMLElement | null;
  const startsTransparent = nav?.classList.contains('bg-brand-bg/90') === false;
  const onScroll = () => {
    if (!nav || !bar || !accent || !startsTransparent) return;
    if (window.scrollY > 40) {
      nav.classList.add('bg-brand-bg/85', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/40');
      bar.classList.replace('py-5', 'py-3');
      accent.classList.replace('scale-x-0', 'scale-x-100');
    } else {
      nav.classList.remove('bg-brand-bg/85', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/40');
      bar.classList.replace('py-3', 'py-5');
      accent.classList.replace('scale-x-100', 'scale-x-0');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const toggle = document.getElementById('nsb-nav-toggle');
  const menu = document.getElementById('nsb-nav-mobile');
  if (toggle && menu) {
    const closeMenu = () => {
      toggle.setAttribute('aria-expanded', 'false');
      menu.classList.remove('is-open');
      document.body.classList.remove('overflow-hidden');
    };
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      menu.classList.toggle('is-open', !isOpen);
      document.body.classList.toggle('overflow-hidden', !isOpen);
    });
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
    window.addEventListener('resize', () => { if (window.innerWidth >= 1024) closeMenu(); });

    // Mobile Services submenu
    menu.querySelectorAll('.nsb-sub-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const panel = btn.nextElementSibling as HTMLElement | null;
        const chevron = btn.querySelector('.nsb-sub-chevron') as HTMLElement | null;
        const open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
        panel?.classList.toggle('is-open', !open);
        if (chevron) chevron.style.transform = open ? '' : 'rotate(180deg)';
      });
    });
  }
</script>
