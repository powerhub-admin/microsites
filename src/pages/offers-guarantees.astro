---
import Layout from '../layouts/Layout.astro';
import Theme from '../components/Theme.astro';
import NavInner from '../components/NavInner.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import Faqs from '../components/Faqs.astro';
import OutlineButton from '../components/OutlineButton.astro';
import Bolt from '../components/Bolt.astro';
import { site } from '../data/site';

const offers = [
  { title: '$50 off your first service', desc: 'New customers across St Ives save $50 on their first booking with Powerhub Electrical, applied automatically at the time of invoicing. Confirm final terms with our team at booking.' },
  { title: '15% pensioner discount', desc: 'Pensioners across St Ives and the wider Ku-ring-gai area receive an automatic 15 per cent discount on every job, applied at the quoting stage rather than buried in the invoice.' },
  { title: 'Free 5-star electrical safety inspection', desc: 'Every booking includes a complimentary five-star electrical safety inspection, giving you a genuine second opinion on your switchboard, wiring and safety switches at no extra cost.' },
];

const promises = [
  { title: 'Transparent, no-pressure advice', desc: 'We explain exactly what\'s wrong and what it will cost before any work begins, and we never pressure you into a bigger job than the one you actually asked for.' },
  { title: 'Obligation-free quotes', desc: 'Every quote from Powerhub Electrical is provided upfront and free of obligation, so you can compare it, think it over, or simply say no without any awkwardness whatsoever.' },
  { title: 'Same-day service where possible', desc: 'We prioritise same-day appointments across St Ives whenever the schedule allows, particularly for problems that genuinely cannot wait until the following day or later.' },
  { title: 'Fair, upfront pricing', desc: 'You are told the cost before agreeing to any work, with no hidden fees added afterwards, so the price you\'re quoted is genuinely the price you pay.' },
];

const offerFaqs = [
  { q: 'Is the $ 50-off first-service offer available to everyone?', a: 'Yes, it\'s available to any new customer across St Ives who books with us for the first time, and it\'s applied automatically when your invoice is finalised.' },
  { q: 'How do I claim the 15% pensioner discount?', a: 'Simply let us know when you book, and the discount is applied automatically at the quoting stage, with no forms or paperwork required.' },
  { q: 'What\'s included in the free safety inspection?', a: 'Every booking includes a broader check of your switchboard, wiring and safety switches, not just the specific job you called about.' },
  { q: 'Do your offers have any hidden conditions?', a: 'No, our offers are designed to be straightforward, though the first-service discount may have final terms confirmed at booking, which we\'re always happy to clarify upfront.' },
  { q: 'Can I combine multiple offers on one job?', a: 'In most cases, yes, for example, a new pensioner customer can generally receive both the first-service saving and the pensioner discount, and we\'ll confirm this clearly during quoting.' },
  { q: 'Do these offers apply to emergency callouts too?', a: 'Yes, the same Powerhub Electrical offers and promises apply whether it\'s a routine booking or a genuine emergency callout across St Ives.' },
];
---
<Theme />
<Layout title="Special Offers & Our Guarantee | Powerhub Electrical St Ives" description="Straightforward offers, honest pricing, and a clear promise on how every job is handled. $50 off your first service, 15% pensioner discount and a free safety inspection.">
  <NavInner />
  <main id="top">
    <PageHero
      eyebrow="Offers & guarantees"
      title="Special offers and our guarantee to"
      accent="St Ives customers"
      sub="Straightforward offers, honest pricing, and a clear promise on how every job is handled."
      crumbs={[{ label: 'Home', href: '/' }, { label: 'Offers & Guarantees' }]}
    >
      <p>Powerhub Electrical backs every booking with genuine electrician offers across St Ives and a straightforward promise about how we work, no matter how big or small the job is.</p>
      <p>Below is exactly what's currently available and what you can expect every time.</p>
    </PageHero>

    <!-- CURRENT OFFERS -->
    <section class="relative bg-brand-surface py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="reveal mb-4 max-w-2xl">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> Current offers
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Current offers for <span class="text-brand-secondary">St Ives customers</span>
          </h2>
        </div>
        <p class="reveal mb-12 max-w-2xl font-body text-lg leading-relaxed text-brand-muted">Powerhub Electrical currently runs three genuine offers for customers across St Ives, including:</p>
        <div class="grid gap-5 lg:grid-cols-3">
          {offers.map((o, i) => (
            <article class="reveal relative flex flex-col border border-brand-secondary/25 bg-brand-bg p-7 transition-colors hover:border-brand-accent/60" style={`clip-path: polygon(0 0, 100% 0, 100% 93%, 96% 100%, 0 100%); transition-delay:${i * 80}ms`}>
              <span class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-brand-secondary to-brand-accent"></span>
              <span class="mb-4 grid h-9 w-9 place-items-center text-brand-bg" style="clip-path: polygon(0 0, 100% 0, 100% 70%, 70% 100%, 0 100%); background: var(--color-brand-secondary);"><Bolt class="h-4 w-4" /></span>
              <h3 class="font-heading text-xl font-black uppercase leading-tight tracking-tight text-brand-secondary">{o.title}</h3>
              <p class="mt-3 font-body text-sm leading-relaxed text-brand-muted">{o.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- OUR PROMISE -->
    <section class="relative bg-brand-bg py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="reveal mb-4 max-w-2xl">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> Our promise
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Our promise on <span class="text-brand-secondary">every job</span>
          </h2>
        </div>
        <p class="reveal mb-12 max-w-2xl font-body text-lg leading-relaxed text-brand-muted">Beyond these offers, a few things stay consistent no matter which job you book with us:</p>
        <div class="grid gap-px overflow-hidden border border-white/5 bg-white/5 sm:grid-cols-2">
          {promises.map((p, i) => (
            <div class="reveal group bg-brand-surface p-8 transition-colors hover:bg-brand-bg" style={`transition-delay: ${(i % 2) * 90}ms;`}>
              <span class="mb-4 grid h-9 w-9 place-items-center text-brand-bg" style="clip-path: polygon(0 0, 100% 0, 100% 70%, 70% 100%, 0 100%); background: var(--color-brand-secondary);">
                <Bolt class="h-4 w-4" />
              </span>
              <h3 class="font-heading text-lg font-bold uppercase leading-tight tracking-tight text-brand-text">{p.title}</h3>
              <p class="mt-2 font-body text-base leading-relaxed text-brand-muted">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CREDENTIALS -->
    <section class="relative bg-brand-surface py-20 sm:py-28">
      <div class="mx-auto max-w-4xl px-5 sm:px-8">
        <div class="reveal mb-4">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> Verify us
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Credentials you can <span class="text-brand-secondary">verify</span>
          </h2>
        </div>
        <p class="reveal mb-8 font-body text-lg leading-relaxed text-brand-muted">These offers sit alongside credentials that are a matter of public record:</p>
        <ul class="space-y-4">
          <li class="reveal flex items-start gap-3 border border-white/8 bg-brand-bg p-5" style="clip-path: polygon(0 0, 100% 0, 99% 100%, 0 100%);">
            <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0 100%);"><Bolt class="h-4 w-4" /></span>
            <span class="font-body text-base leading-relaxed text-brand-text">Powerhub Electrical holds Electrical Contractor Licence #467291C, verifiable through the <a href="https://verify.licence.nsw.gov.au/details/Contractor%20Licence/1-46C84T5" target="_blank" rel="noopener noreferrer" class="font-semibold text-brand-secondary underline decoration-brand-accent/50 underline-offset-4 hover:text-brand-accent">NSW licence register</a></span>
          </li>
          <li class="reveal flex items-start gap-3 border border-white/8 bg-brand-bg p-5" style="clip-path: polygon(0 0, 100% 0, 99% 100%, 0 100%); transition-delay:60ms;">
            <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0 100%);"><Bolt class="h-4 w-4" /></span>
            <span class="font-body text-base leading-relaxed text-brand-text"><a href="https://abr.business.gov.au/ABN/View?id=91677354602" target="_blank" rel="noopener noreferrer" class="font-semibold text-brand-secondary underline decoration-brand-accent/50 underline-offset-4 hover:text-brand-accent">ABN 91 677 354 602</a>, searchable through the Australian Business Register</span>
          </li>
          <li class="reveal flex items-start gap-3 border border-white/8 bg-brand-bg p-5" style="clip-path: polygon(0 0, 100% 0, 99% 100%, 0 100%); transition-delay:120ms;">
            <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0 100%);"><Bolt class="h-4 w-4" /></span>
            <span class="font-body text-base leading-relaxed text-brand-text">Under Australian Consumer Law, any service must be carried out with due care and skill, a protection that applies in addition to anything offered here</span>
          </li>
        </ul>
      </div>
    </section>

    <Faqs heading="Frequently asked questions" items={offerFaqs} bg="bg-brand-bg" />

    <!-- CTA -->
    <section class="relative overflow-hidden bg-brand-surface py-24">
      <div class="pointer-events-none absolute inset-0 opacity-[0.06]" style="background-image: linear-gradient(90deg, var(--color-brand-secondary) 1px, transparent 1px); background-size: 50px 50px;"></div>
      <div class="relative mx-auto max-w-4xl px-5 text-center sm:px-8">
        <p class="reveal mb-5 inline-flex items-center gap-2 border border-brand-accent/50 bg-brand-accent/10 px-4 py-1.5 font-heading text-xs font-bold uppercase tracking-widest text-brand-accent pulse-glow">
          <Bolt class="h-3.5 w-3.5" /> Book and save
        </p>
        <h2 class="reveal font-heading text-[clamp(2rem,5.5vw,3.6rem)] font-black uppercase leading-[1.0] tracking-[-0.01em] text-brand-text" style="transition-delay:80ms;">
          Want to book <span class="text-brand-accent">and save?</span>
        </h2>
        <p class="reveal mx-auto mt-6 max-w-2xl font-body text-lg leading-relaxed text-brand-muted" style="transition-delay:160ms;">
          Call Powerhub Electrical on {site.phoneDisplay} to book your job. New customers save $50, pensioners save 15 per cent, and every booking includes a free five-star safety inspection and an honest, obligation-free quote.
        </p>
        <div class="reveal mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row" style="transition-delay:240ms;">
          <a href={site.phoneHref} class="sweep-btn group relative inline-flex items-center justify-center gap-2 overflow-hidden px-8 py-4 font-heading text-base font-bold text-brand-bg" style="clip-path: polygon(6% 0, 100% 0, 94% 100%, 0 100%); background: var(--color-brand-accent);">
            <span class="relative z-10">Call {site.phoneDisplay}</span>
            <Bolt class="relative z-10 h-4 w-4" />
          </a>
          <OutlineButton href="/contact-us" class="px-8 py-4 text-base">Get a Free Quote</OutlineButton>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
