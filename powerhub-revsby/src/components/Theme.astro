---
/*
  Powerhub Electrical — palette + shared motion.
  "North Shore Bold" dark aesthetic recoloured to the Powerhub brand:
  orange (#ff9a00) highlights + deeper orange (#ff6a00) CTAs on charcoal.
  Include <Theme /> once near the top of every Powerhub page.
*/
---
<style is:global>
  :root {
    --color-brand-primary:   #1f2124;
    --color-brand-secondary: #ff9a00;
    --color-brand-accent:    #ff6a00;
    --color-brand-bg:        #17181b;
    --color-brand-surface:   #232428;
    --color-brand-text:      #f4f4f6;
    --color-brand-muted:     #a3a3a3;
    --font-heading: 'Exo 2 Variable', system-ui, sans-serif;
    --font-body:    'DM Sans Variable', system-ui, sans-serif;
  }
  html { scroll-behavior: smooth; }
  body { background: var(--color-brand-bg); color: var(--color-brand-text); font-family: var(--font-body); }
  ::selection { background: var(--color-brand-accent); color: var(--color-brand-bg); }

  .reveal { opacity: 0; transform: translateY(26px); transition: opacity 0.6s cubic-bezier(0.2,0.8,0.2,1), transform 0.6s cubic-bezier(0.2,0.8,0.2,1); }
  .reveal.is-visible { opacity: 1; transform: translateY(0); }

  .sweep-btn::before {
    content: '';
    position: absolute;
    inset: -2px -20%;
    background: var(--color-brand-secondary);
    transform: translateX(-120%) skewX(-20deg);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .sweep-btn:hover::before { transform: translateX(0) skewX(-20deg); }

  /* Slanted outline button: the border follows the same parallelogram as the
     filled buttons on all four edges (including the left/right slants), and the
     inside stays transparent so it sits cleanly over any background. */
  .slant-outline { position: relative; }
  .slant-outline .slant-fill {
    position: absolute; inset: 0;
    clip-path: polygon(6% 0, 100% 0, 94% 100%, 0 100%);
    background-color: transparent;
    transition: background-color 0.2s ease;
  }
  .slant-outline:hover .slant-fill { background-color: color-mix(in srgb, currentColor 12%, transparent); }
  .slant-outline .slant-stroke {
    position: absolute; inset: 0; width: 100%; height: 100%;
    overflow: visible; fill: none;
    stroke: currentColor; stroke-opacity: 0.5; stroke-width: 1.5px;
  }

  .pulse-glow { animation: pulseGlow 2.6s ease-in-out infinite; }
  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255, 106, 0, 0.45); }
    50% { box-shadow: 0 0 20px 3px rgba(255, 106, 0, 0.55); }
  }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    .reveal { opacity: 1; transform: none; transition: none; }
    .pulse-glow { animation: none; }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
