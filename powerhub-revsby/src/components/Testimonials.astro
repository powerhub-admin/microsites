---
import Bolt from './Bolt.astro';

const reviews = [
  { quote: "Brian did an amazing job for us at our 1 bedroom apartment. We had ceiling fans installed, powerpoints added and all was professionally done within half a day. Will not hesitate to recommend Brian for any electrical works.", name: 'Sarah Yong' },
  { quote: "Brian was so helpful and solved a potentially dangerous issue (a melted fuse box) quickly and with a great deal of care. He was clear with his communication, incredibly knowledgeable, and super responsive. I cannot recommend Powerhub Electrical more.", name: 'Georgia Mason' },
  { quote: "Highly recommend Brian & his team. His workmanship is outstanding as is his communication. Nothing was too much trouble and the jobs were completed in a very timely manner. Will definitely use again!", name: 'Kellie Scott' },
];
---
<section class="relative overflow-hidden bg-brand-surface py-24">
  <img src="/images/powerhub/home/work-3.webp" alt="" aria-hidden="true" class="pointer-events-none absolute inset-y-0 right-0 h-full w-1/2 object-cover opacity-15" style="clip-path: polygon(18% 0, 100% 0, 100% 100%, 0 100%); mask-image: linear-gradient(to right, transparent, black 60%);" />
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-r from-brand-surface via-brand-surface/90 to-transparent"></div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-8 lg:px-8">
    <div class="reveal mb-12 max-w-2xl">
      <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
        <span class="inline-block h-px w-10 bg-brand-accent"></span>
        What Revesby homeowners say
      </p>
      <h2 class="font-heading text-[clamp(1.9rem,4.5vw,3rem)] font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text">
        Backed by <span class="text-brand-secondary">100+ five-star</span> reviews
      </h2>
    </div>

    <div class="-mx-5 flex snap-x snap-mandatory gap-5 overflow-x-auto px-5 pb-4 sm:mx-0 sm:grid sm:grid-cols-3 sm:overflow-visible sm:px-0">
      {reviews.map((r, i) => (
        <figure class="reveal group relative min-w-[82%] shrink-0 snap-center border border-white/5 bg-brand-bg p-7 sm:min-w-0" style={`transition-delay: ${i * 110}ms; clip-path: polygon(0 0, 100% 0, 100% 92%, 96% 100%, 0 100%);`}>
          <span class="absolute left-0 top-0 h-1 w-0 bg-brand-accent transition-all duration-300 group-hover:w-full"></span>
          <div class="mb-4 flex gap-1 text-brand-secondary" aria-label="5 out of 5 stars">
            {[...Array(5)].map(() => <Bolt class="h-4 w-4" />)}
          </div>
          <blockquote class="font-body text-base leading-relaxed text-brand-text">"{r.quote}"</blockquote>
          <figcaption class="mt-6 border-t border-white/10 pt-4 font-heading text-sm font-bold uppercase tracking-wide text-brand-secondary">
            {r.name}{r.suburb && <span class="ml-2 font-body text-xs font-normal normal-case text-brand-muted">{r.suburb}</span>}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
