---
const steps = [
  { n: '01', title: 'Enquiry and free quote', desc: 'Revesby customers call or message to describe the issue and receive an obligation-free quote before a technician is ever booked.' },
  { n: '02', title: 'Same day scheduling', desc: 'Most Revesby bookings are scheduled for the same day, with emergency callouts prioritised ahead of routine maintenance and installation work.' },
  { n: '03', title: 'On-site diagnosis', desc: 'The electrician inspects the switchboard, wiring or fitting in question and explains the fault in plain language before starting work.' },
  { n: '04', title: 'Upfront fixed pricing', desc: 'A fixed price is confirmed before any tools come out, so Revesby customers know the full cost of the job.' },
  { n: '05', title: 'Compliant sign off', desc: 'Finished work is tested, certified to AS/NZS 3000 and left clean, with paperwork provided for insurance or strata records immediately.' },
];
---
<section id="process" class="relative overflow-hidden bg-brand-bg py-24">
  <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16 lg:px-8">
    <div>
      <div class="reveal mb-4 max-w-xl">
        <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
          <span class="inline-block h-px w-10 bg-brand-accent"></span>
          How we work
        </p>
        <h2 class="font-heading text-[clamp(1.9rem,4.5vw,3rem)] font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text">
          Our electrician process <span class="text-brand-secondary">for Revesby bookings</span>
        </h2>
      </div>
      <p class="reveal mb-10 max-w-xl font-body text-base leading-relaxed text-brand-muted">
        Booking an electrician in Revesby with us follows a simple, transparent sequence from first call to sign-off:
      </p>

      <ol class="relative space-y-8 border-l border-brand-secondary/20 pl-8">
        {steps.map((s, i) => (
          <li class="reveal relative" style={`transition-delay: ${i * 90}ms;`}>
            <span class="absolute -left-[42px] grid h-8 w-8 place-items-center font-heading text-xs font-black text-brand-bg" style="clip-path: polygon(20% 0, 100% 0, 80% 100%, 0 100%); background: var(--color-brand-accent);">{s.n}</span>
            <h3 class="font-heading text-xl font-black uppercase leading-tight tracking-tight text-brand-secondary">{s.title}</h3>
            <p class="mt-2 max-w-md font-body text-base leading-relaxed text-brand-muted">{s.desc}</p>
          </li>
        ))}
      </ol>
    </div>

    <div class="reveal relative" style="transition-delay: 120ms;">
      <div class="relative bg-brand-secondary/25 p-0.5 shadow-2xl shadow-black/60" style="clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%, 0 8%);">
        <div class="relative h-full w-full overflow-hidden" style="clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%, 0 8%);">
          <img src="/images/powerhub/home/why-choose.webp" alt="Powerhub Electrical carrying out work at a Revesby home" class="h-full w-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-tr from-brand-bg/50 to-transparent"></div>
        </div>
      </div>
      <span class="absolute -bottom-4 -left-4 h-20 w-1.5 bg-brand-accent lg:h-28"></span>
    </div>
  </div>
</section>
