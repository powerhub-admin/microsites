---
const suburbs = ['Revesby','Revesby Heights','Padstow','Padstow Heights','Panania','Milperra','Picnic Point','Condell Park','East Hills','Bankstown','Bass Hill','Georges Hall','Yagoona','Chullora','Greenacre','Lansdowne','Villawood','Sefton','Padstow Park','Riverwood','Peakhurst','Mortdale','Hurstville','Bankstown Aerodrome'];
---
<section id="areas" class="relative overflow-hidden bg-brand-surface py-24">
  <div class="mx-auto grid max-w-7xl items-start gap-12 px-5 sm:px-8 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16 lg:px-8">
    <div class="reveal relative">
      <div class="aspect-[4/5] bg-brand-secondary/25 p-0.5 shadow-2xl shadow-black/50 sm:aspect-square" style="clip-path: polygon(0 0, 100% 0, 100% 90%, 92% 100%, 0 100%);">
        <div class="h-full w-full overflow-hidden bg-brand-bg" style="clip-path: polygon(0 0, 100% 0, 100% 90%, 92% 100%, 0 100%);">
          <img
            src="/images/powerhub/home/st-ives-map.webp"
            alt="Map of the Revesby and greater Sydney service area covered by Powerhub Electrical"
            class="h-full w-full object-cover grayscale-[0.2] contrast-[1.05]"
            loading="lazy"
          />
        </div>
      </div>
      <span class="absolute -bottom-4 left-6 h-20 w-1.5 bg-brand-accent"></span>
    </div>

    <div>
      <div class="reveal mb-8 max-w-xl" style="transition-delay: 100ms;">
        <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
          <span class="inline-block h-px w-10 bg-brand-accent"></span>
          Areas we service
        </p>
        <h2 class="font-heading text-[clamp(1.9rem,4.5vw,3rem)] font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text">
          Revesby &amp; <span class="text-brand-secondary">greater Sydney</span>
        </h2>
        <p class="mt-4 font-body text-base leading-relaxed text-brand-muted">From Revesby across the Canterbury-Bankstown area and the wider greater Sydney region, we're never far away. Don't see your suburb? Give us a call, chances are we're already nearby.</p>
      </div>
      <ul class="reveal flex flex-wrap gap-2" style="transition-delay: 180ms;">
        {suburbs.map((s) => (
          <li class="border border-white/8 bg-brand-bg px-3 py-1.5 font-body text-sm text-brand-text transition-colors hover:border-brand-accent/60 hover:text-brand-secondary">{s}</li>
        ))}
      </ul>
    </div>
  </div>
</section>
