---
import Layout from '../layouts/Layout.astro';
import Theme from '../components/Theme.astro';
import NavInner from '../components/NavInner.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
import { services } from '../data/services';
---
<Theme />
<Layout title="Electrical Services Revesby | Powerhub Electrical" description="From emergency callouts to switchboard upgrades, rewires and smoke alarms, Powerhub Electrical covers every electrical job across Revesby and greater Sydney.">
  <NavInner />
  <main id="top">
    <PageHero
      eyebrow="What we do"
      title="Electrical services in"
      accent="Revesby"
      sub="Licensed, insured and backed by 100+ five-star reviews. From a single power point to a full home rewire, our Revesby electricians do it right the first time."
      crumbs={[{ label: 'Home', href: '/' }, { label: 'Services' }]}
      badges={['Same-day service', 'Fixed pricing', 'Obligation-free quotes', 'Licensed #467291C']}
    />

    <section class="relative bg-brand-surface py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="reveal mb-12 max-w-2xl">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> Full-service electrical
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Every job, done <span class="text-brand-secondary">properly</span>
          </h2>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {services.map((s, i) => (
            <a href={`/services/${s.slug}`} class="reveal group block overflow-hidden border border-white/8 bg-brand-bg transition-colors hover:border-brand-accent/50" style={`clip-path: polygon(0 0, 100% 0, 97% 100%, 0 100%); transition-delay:${(i % 4) * 60}ms`}>
              <div class="overflow-hidden">
                <img src={s.img} alt={s.alt} class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              </div>
              <div class="p-5">
                <h3 class="font-heading text-base font-black uppercase tracking-[-0.01em] text-brand-text group-hover:text-brand-secondary">{s.navLabel}</h3>
                <p class="mt-2 font-body text-sm leading-relaxed text-brand-muted">{s.tagline}</p>
                <span class="mt-3 inline-flex items-center gap-1 font-heading text-xs font-bold uppercase tracking-widest text-brand-accent">Learn more →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTASection />
  </main>
  <Footer />
</Layout>
