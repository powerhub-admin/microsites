---
import Layout from '../layouts/Layout.astro';
import Theme from '../components/Theme.astro';
import NavInner from '../components/NavInner.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import Faqs from '../components/Faqs.astro';
import OutlineButton from '../components/OutlineButton.astro';
import Bolt from '../components/Bolt.astro';
import { site } from '../data/site';

const linkClass = 'font-semibold text-brand-secondary underline decoration-brand-accent/50 underline-offset-4 hover:text-brand-accent';

const path = [
  { n: '01', title: 'Starting the Trade Early', desc: 'Brian took up his electrical apprenticeship in his final year of high school, drawn to hands-on work over a desk job. Close to ten years later, at 30, he still gets mistaken for someone much younger on site.' },
  { n: '02', title: 'From Apprentice to Director', desc: 'Brian\'s early career moved through domestic and commercial construction before shifting toward maintenance work with a stronger focus on customer service. In 2023, he founded Powerhub Electrical, wanting a business built around honesty rather than volume.' },
  { n: '03', title: 'A Personal Standard on Every Job', desc: 'Brian holds Electrical Supervisor Licence #467291C and stays personally involved in the standard of work across Revesby jobs, rather than handing quality control to someone else further down the chain.' },
];

const drives = [
  { title: 'Integrity in Actions and Words', desc: 'Brian describes his values simply: being upfront and honest with people, and respecting other people\'s time and differences. It is the same standard he expects from anyone working under the Powerhub Electrical name.' },
  { title: 'Doing the Job Right the First Time', desc: 'Brian is a firm believer that if there is not enough time or money to do a job properly the first time, there will not be enough the second time either.' },
  { title: 'Educating Rather Than Just Fixing', desc: 'Rather than simply completing a repair, Brian\'s approach involves understanding the underlying problem, explaining it in plain language, and offering a genuine solution rather than a temporary patch.' },
  { title: 'Treating Every Property Like His Own', desc: 'The promise behind every job is straightforward. If it is not good enough for Brian\'s own home, it is not good enough to leave behind in someone else\'s.' },
];

const aboutFaqs = [
  { q: 'Who is my Revesby electrician if I book with Powerhub Electrical?', a: 'Every Revesby electrician booking is overseen by Brian Ho, the director and licence holder, rather than being handed off to an unnamed contractor.' },
  { q: 'How long has Brian Ho been an electrician?', a: 'Brian started his apprenticeship in his final year of high school and has been working in the trade for close to ten years now, at age 30.' },
  { q: 'Is Powerhub Electrical a licensed and insured business?', a: 'Yes, Powerhub Electrical operates under Electrical Supervisor Licence #467291C and carries insurance for all electrical work completed across Revesby and the greater Sydney region as a registered business.' },
  { q: 'Does Brian Ho personally attend every job in Revesby?', a: 'Brian oversees every job as director, though jobs may be attended by him or a trusted team member, always working to the same licensed standard.' },
  { q: 'What areas does Powerhub Electrical\'s Revesby team cover?', a: 'Revesby sits within Powerhub Electrical\'s greater Sydney coverage area, serviced from the Epping base, with jobs scheduled to keep travel times reasonable for customers booking in advance.' },
  { q: 'What happens if I\'m not happy with the work?', a: 'Brian\'s approach is to explain the fault, the fix and the cost upfront, and to stand behind the workmanship rather than leaving a customer with an unresolved problem.' },
];
---
<Theme />
<Layout title="Meet Your Revesby Electrician | Powerhub Electrical" description="Meet Brian Ho, director and licensed electrician behind Powerhub Electrical in Revesby. Licensed, insured and backed by 100+ reviews. Call 0400 332 331.">
  <NavInner />
  <main id="top">
    <PageHero
      eyebrow="About us"
      title="Meet Your"
      accent="Revesby Electrician"
      sub="Your Revesby electrician is backed by a real name, licence number and a business built on doing things properly. Brian Ho leads every job personally."
      crumbs={[{ label: 'Home', href: '/' }, { label: 'About Us' }]}
      img="/images/powerhub/home/why-choose.webp"
    />

    <!-- BRIAN INTRO -->
    <section class="relative bg-brand-bg py-20 sm:py-28">
      <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
        <div class="reveal relative">
          <div class="relative bg-brand-secondary/30 p-0.5 shadow-2xl shadow-black/60" style="clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%);">
            <div class="h-full w-full overflow-hidden" style="clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%);">
              <img src="/images/powerhub/home/help.webp" alt="Brian Ho, founder and licensed electrician at Powerhub Electrical" class="h-full w-full object-cover" />
            </div>
          </div>
          <div class="absolute -bottom-5 -right-3 bg-brand-secondary px-5 py-3 font-heading font-black uppercase text-brand-bg" style="clip-path: polygon(6% 0, 100% 0, 94% 100%, 0 100%);">
            Brian Ho
            <span class="block text-xs font-semibold tracking-wide opacity-80">Founder &amp; Licensed Electrician</span>
          </div>
          <span class="absolute -left-4 top-10 h-24 w-1.5 -skew-y-12 bg-brand-accent"></span>
        </div>

        <div class="reveal" style="transition-delay:120ms;">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> Meet Brian Ho
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.05] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Why Revesby Customers Want to Know <span class="text-brand-secondary">Who's Coming</span>
          </h2>
          <p class="mt-6 max-w-xl font-body text-lg font-medium leading-relaxed text-brand-secondary">
            A small, director-led electrical business with 100+ positive reviews and 25+ years combined trade experience.
          </p>
          <p class="mt-4 max-w-xl font-body text-lg leading-relaxed text-brand-muted">
            Most people want to know who is actually turning up before they let someone into their home. This page introduces Brian Ho, the director standing behind every quote, and the values that shape how Powerhub Electrical works across Revesby and greater Sydney.
          </p>
        </div>
      </div>
    </section>

    <!-- PATH -->
    <section class="relative bg-brand-surface py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="reveal mb-4 max-w-2xl">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> The journey
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Brian's <span class="text-brand-secondary">Path Into the Trade</span>
          </h2>
        </div>
        <p class="reveal mb-12 max-w-2xl font-body text-lg leading-relaxed text-brand-muted">Brian Ho's journey from apprentice to director shapes how every job in Revesby is handled today:</p>
        <div class="grid gap-5 lg:grid-cols-3">
          {path.map((p, i) => (
            <div class="reveal relative border border-white/8 bg-brand-bg p-7 transition-colors hover:border-brand-accent/40" style={`clip-path: polygon(0 0, 100% 0, 97% 100%, 0 100%); transition-delay:${i * 80}ms`}>
              <span class="font-heading text-4xl font-black tracking-[-0.03em] text-brand-secondary/30">{p.n}</span>
              <h3 class="mt-3 font-heading text-lg font-black uppercase tracking-[-0.01em] text-brand-text">{p.title}</h3>
              <p class="mt-2 font-body text-sm leading-relaxed text-brand-muted">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- DRIVES -->
    <section class="relative bg-brand-bg py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="reveal mb-4 max-w-2xl">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> Our values
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            What Brian <span class="text-brand-secondary">Believes In</span>
          </h2>
        </div>
        <p class="reveal mb-12 max-w-2xl font-body text-lg leading-relaxed text-brand-muted">These principles come directly from how Brian was raised and how he runs the business day to day:</p>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {drives.map((d, i) => (
            <article class="reveal border border-white/8 bg-brand-surface p-6 transition-colors hover:border-brand-accent/50" style={`clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%); transition-delay:${i * 60}ms`}>
              <span class="mb-4 inline-flex h-9 w-9 items-center justify-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 85% 100%, 0 100%);">
                <Bolt class="h-5 w-5" />
              </span>
              <h3 class="font-heading text-lg font-black uppercase tracking-[-0.01em] text-brand-text">{d.title}</h3>
              <p class="mt-2 font-body text-sm leading-relaxed text-brand-muted">{d.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CREDENTIALS -->
    <section class="relative bg-brand-surface py-20 sm:py-28">
      <div class="mx-auto max-w-4xl px-5 sm:px-8">
        <div class="reveal mb-4">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> Verify us
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Licensing and <span class="text-brand-secondary">Credentials</span>
          </h2>
        </div>
        <p class="reveal mb-8 font-body text-lg leading-relaxed text-brand-muted">Here is how to independently confirm Powerhub Electrical's credentials before booking:</p>
        <ul class="space-y-4">
          <li class="reveal flex items-start gap-3 border border-white/8 bg-brand-bg p-5" style="clip-path: polygon(0 0, 100% 0, 99% 100%, 0 100%);">
            <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0 100%);"><Bolt class="h-4 w-4" /></span>
            <span class="font-body text-base leading-relaxed text-brand-text">Electrical Supervisor Licence #467291C, checkable directly through <a href="https://www.service.nsw.gov.au/transaction/check-a-builder-or-tradesperson-licence" target="_blank" rel="noopener noreferrer" class={linkClass}>Service NSW's licence verification tool</a></span>
          </li>
          <li class="reveal flex items-start gap-3 border border-white/8 bg-brand-bg p-5" style="clip-path: polygon(0 0, 100% 0, 99% 100%, 0 100%); transition-delay:60ms;">
            <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0 100%);"><Bolt class="h-4 w-4" /></span>
            <span class="font-body text-base leading-relaxed text-brand-text">Registered business operating under <a href="https://abr.business.gov.au/ABN/View?id=91677354602" target="_blank" rel="noopener noreferrer" class={linkClass}>ABN 91 677 354 602</a></span>
          </li>
          <li class="reveal flex items-start gap-3 border border-white/8 bg-brand-bg p-5" style="clip-path: polygon(0 0, 100% 0, 99% 100%, 0 100%); transition-delay:120ms;">
            <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0 100%);"><Bolt class="h-4 w-4" /></span>
            <span class="font-body text-base leading-relaxed text-brand-text">Trained through the standard NSW electrical apprenticeship pathway</span>
          </li>
          <li class="reveal flex items-start gap-3 border border-white/8 bg-brand-bg p-5" style="clip-path: polygon(0 0, 100% 0, 99% 100%, 0 100%); transition-delay:180ms;">
            <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0 100%);"><Bolt class="h-4 w-4" /></span>
            <span class="font-body text-base leading-relaxed text-brand-text">100+ positive reviews and 25+ years of combined trade experience across the team</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- LIFE OUTSIDE -->
    <section class="relative bg-brand-bg py-20 sm:py-28">
      <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-[1.15fr_0.85fr] lg:gap-16">
        <div class="reveal">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> Off the tools
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Life Outside <span class="text-brand-secondary">the Tools</span>
          </h2>
          <p class="mt-6 max-w-xl font-body text-lg leading-relaxed text-brand-muted">
            Away from jobs, Brian is usually at the gym, trying a new cafe or brunch spot, or spending time with his mum, brother, partner and their corgi. His standing coffee order is a 7/11 iced coffee with a double espresso and a dash of milk, ordered at 7:30 am without fail.
          </p>
        </div>
        <div class="reveal relative" style="transition-delay:120ms;">
          <div class="relative bg-brand-secondary/25 p-0.5 shadow-2xl shadow-black/60" style="clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%);">
            <div class="h-full w-full overflow-hidden" style="clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%);">
              <img src="/images/powerhub/home/work-6.webp" alt="Brian Ho of Powerhub Electrical around Revesby and Canterbury-Bankstown" class="h-full w-full object-cover" />
            </div>
          </div>
          <span class="absolute -bottom-4 -right-3 h-24 w-1.5 bg-brand-accent"></span>
        </div>
      </div>
    </section>

    <!-- TRADE COMMUNITY -->
    <section class="relative bg-brand-surface py-20 sm:py-28">
      <div class="mx-auto max-w-4xl px-5 sm:px-8">
        <div class="reveal mb-4">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> Community
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Involved in the <span class="text-brand-secondary">Trade Community</span>
          </h2>
        </div>
        <p class="reveal font-body text-lg leading-relaxed text-brand-muted">
          Brian stays connected to other tradespeople through trade support networks and business networking groups such as BNI, keeping him up to date with standards, referrals and the wider Sydney trade community.
        </p>
      </div>
    </section>

    <ServiceAreas />

    <!-- CTA -->
    <section class="relative overflow-hidden bg-brand-surface py-24">
      <div class="pointer-events-none absolute inset-0 opacity-[0.06]" style="background-image: linear-gradient(90deg, var(--color-brand-secondary) 1px, transparent 1px); background-size: 50px 50px;"></div>
      <div class="relative mx-auto max-w-4xl px-5 text-center sm:px-8">
        <p class="reveal mb-5 inline-flex items-center gap-2 border border-brand-accent/50 bg-brand-accent/10 px-4 py-1.5 font-heading text-xs font-bold uppercase tracking-widest text-brand-accent pulse-glow">
          <Bolt class="h-3.5 w-3.5" /> Talk to Brian first
        </p>
        <h2 class="reveal font-heading text-[clamp(2rem,5.5vw,3.4rem)] font-black uppercase leading-[1.0] tracking-[-0.01em] text-brand-text" style="transition-delay:80ms;">
          Want the Same Director-Led <span class="text-brand-accent">Approach on Your Job?</span>
        </h2>
        <p class="reveal mx-auto mt-6 max-w-2xl font-body text-lg leading-relaxed text-brand-muted" style="transition-delay:160ms;">
          Call Powerhub Electrical Revesby on {site.phoneDisplay} to speak directly about a job in Revesby. New customers save $50 on their first service, and every quote remains obligation-free, backed by Brian's Electrical Supervisor Licence #467291C.
        </p>
        <div class="reveal mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row" style="transition-delay:240ms;">
          <a href={site.phoneHref} class="sweep-btn group relative inline-flex items-center justify-center gap-2 overflow-hidden px-8 py-4 font-heading text-base font-bold text-brand-bg" style="clip-path: polygon(6% 0, 100% 0, 94% 100%, 0 100%); background: var(--color-brand-accent);">
            <span class="relative z-10">Call {site.phoneDisplay}</span>
            <Bolt class="relative z-10 h-4 w-4" />
          </a>
          <OutlineButton href="/contact-us" class="px-8 py-4 text-base">Get a Free Quote</OutlineButton>
        </div>
      </div>
    </section>

    <Faqs heading="Frequently Asked Questions" items={aboutFaqs} bg="bg-brand-bg" />
  </main>
  <Footer />
</Layout>
