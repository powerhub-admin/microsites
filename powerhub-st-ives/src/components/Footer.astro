---
import Bolt from './Bolt.astro';
import { site } from '../data/site';
import { services } from '../data/services';

const explore = [
  { label: 'About Us', href: '/about-us' },
  { label: 'Services', href: '/services' },
  { label: 'FAQs', href: '/faqs' },
  { label: 'Offers & Guarantees', href: '/offers-guarantees' },
  { label: 'Contact Us', href: '/contact-us' },
];
const popular = services.slice(0, 6);
---
<footer class="relative overflow-hidden bg-brand-bg pt-16">
  <span class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-brand-secondary via-brand-accent to-brand-secondary"></span>
  <div class="mx-auto max-w-7xl px-5 sm:px-8 lg:px-8">
    <div class="grid gap-10 border-b border-white/8 pb-12 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-1">
        <a href={site.home} class="flex items-center" aria-label="Powerhub Electrical home">
          <img src="/images/powerhub/logo.webp" alt="Powerhub Electrical" width="300" height="99" class="h-16 w-auto" />
        </a>
        <p class="mt-4 max-w-xs font-body text-sm leading-relaxed text-brand-muted">Your trusted local electrician in St Ives. Licensed, insured, and backed by 100+ five-star reviews across the Upper North Shore.</p>
        <p class="mt-4 font-heading text-xs font-bold uppercase tracking-widest text-brand-secondary">Same-day service · 24/7 emergencies</p>
      </div>

      <div>
        <h3 class="mb-4 font-heading text-xs font-bold uppercase tracking-widest text-brand-secondary">Explore</h3>
        <ul class="space-y-2.5">
          {explore.map((l) => (
            <li><a href={l.href} class="font-body text-sm text-brand-muted transition-colors hover:text-brand-text">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 font-heading text-xs font-bold uppercase tracking-widest text-brand-secondary">Popular services</h3>
        <ul class="space-y-2.5">
          {popular.map((s) => (
            <li><a href={`/services/${s.slug}`} class="font-body text-sm text-brand-muted transition-colors hover:text-brand-text">{s.navLabel}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 font-heading text-xs font-bold uppercase tracking-widest text-brand-secondary">Contact</h3>
        <ul class="space-y-2.5 font-body text-sm text-brand-muted">
          <li><a href={site.phoneHref} class="transition-colors hover:text-brand-text">{site.phoneDisplay}</a></li>
          <li><a href={site.emailHref} class="transition-colors hover:text-brand-text">{site.email}</a></li>
          <li>St Ives &amp; the Upper North Shore</li>
        </ul>
        <a href="/contact-us" class="sweep-btn group relative mt-5 inline-flex items-center gap-2 overflow-hidden px-5 py-3 font-heading text-sm font-bold text-brand-bg" style="clip-path: polygon(6% 0, 100% 0, 94% 100%, 0 100%); background: var(--color-brand-accent);">
          <span class="relative z-10">Book Now</span><Bolt class="relative z-10 h-3.5 w-3.5" />
        </a>
      </div>
    </div>

    <div class="flex flex-col items-center justify-between gap-3 py-6 sm:flex-row">
      <p class="font-body text-xs text-brand-muted">© 2026 Powerhub Electrical. {site.licence}. {site.abn}.</p>
      <p class="font-heading text-xs font-bold uppercase tracking-widest text-brand-secondary">Your local St Ives electrician</p>
    </div>
  </div>
</footer>
