---
import Layout from '../layouts/Layout.astro';
import Theme from '../components/Theme.astro';
import NavInner from '../components/NavInner.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import Faqs from '../components/Faqs.astro';
import OutlineButton from '../components/OutlineButton.astro';
import Bolt from '../components/Bolt.astro';
import { site } from '../data/site';

const path = [
  { n: '01', title: 'Starting the apprenticeship at twenty', desc: 'Brian began his electrical apprenticeship at twenty, later moving from commercial and domestic construction sites into residential maintenance work, where the direct contact with homeowners suited him better.' },
  { n: '02', title: 'Ten years on the tools', desc: 'A decade later, Brian has spent his career on the tools rather than behind a desk, preferring hands-on problem-solving, meeting new people, and having no two days look the same.' },
  { n: '03', title: 'Founding Powerhub Electrical in 2023', desc: 'Powerhub Electrical began in 2023, built on the belief that people who invest time and care in their community and clients ultimately receive that same care in return.' },
];

const drives = [
  { title: 'Doing the job right the first time', desc: 'Brian believes that if there isn\'t time or money to do a job properly the first time, there won\'t be time or money to fix it properly the second time either.' },
  { title: 'Honest, upfront communication', desc: 'Being straightforward with clients, respecting their time, and explaining problems in plain language matter more here than sounding impressive or overselling a bigger job than necessary.' },
  { title: 'Solving problems, not just jobs', desc: 'Every visit starts with understanding what\'s actually bothering a homeowner, explaining the options clearly, and giving the time needed to help them make an informed decision.' },
];

const aboutFaqs = [
  { q: 'Is Powerhub Electrical a licensed and insured electrician in St Ives?', a: 'Yes, Powerhub Electrical holds NSW Electrical Contractor Licence 467291C, which you can verify directly through the NSW Government licence register before booking any work.' },
  { q: 'Does Brian personally work on jobs across St Ives?', a: 'Yes, Brian personally scopes and completes many jobs across St Ives, particularly switchboard upgrades, rewiring, and larger projects requiring his direct attention.' },
  { q: 'How long have you been in the electrical trade?', a: 'Brian started his apprenticeship at twenty and has spent the past ten years on the tools, moving from commercial construction into residential maintenance work.' },
  { q: 'What areas around St Ives does Powerhub Electrical service?', a: 'We service St Ives and the surrounding Ku-ring-gai and Upper North Shore suburbs, with same-day appointments available wherever our schedule allows.' },
  { q: 'Why did you start Powerhub Electrical?', a: 'Powerhub Electrical began in 2023 because Brian wanted to run a business built on honest communication, fair pricing, and genuine care for the client\'s outcome.' },
  { q: 'How can I verify your ABN and licence details?', a: 'Both are public record, searchable through the Australian Business Register for the ABN and through the NSW Government\'s licence portal for the electrical licence.' },
];
---
<Theme />
<Layout title="About Your St Ives Electrician | Powerhub Electrical" description="Meet Brian Ho and the team behind Powerhub Electrical, your licensed, family-run electrician serving St Ives. Call 0400 332 331 for honest, local service.">
  <NavInner />
  <main id="top">
    <PageHero
      eyebrow="About us"
      title="Meet your trusted electrician in"
      accent="St Ives"
      sub="Getting to know the person behind the licence matters, especially before letting someone into your home. This page covers exactly who that is."
      crumbs={[{ label: 'Home', href: '/' }, { label: 'About Us' }]}
      img="/images/powerhub/home/why-choose.webp"
    />

    <!-- BRIAN INTRO -->
    <section class="relative bg-brand-bg py-20 sm:py-28">
      <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
        <div class="reveal relative">
          <div class="relative bg-brand-secondary/30 p-0.5 shadow-2xl shadow-black/60" style="clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%);">
            <div class="h-full w-full overflow-hidden" style="clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%);">
              <img src="/images/powerhub/home/help.webp" alt="Brian Ho, founder and licensed electrician at Powerhub Electrical" class="h-full w-full object-cover" />
            </div>
          </div>
          <div class="absolute -bottom-5 -right-3 bg-brand-secondary px-5 py-3 font-heading font-black uppercase text-brand-bg" style="clip-path: polygon(6% 0, 100% 0, 94% 100%, 0 100%);">
            Brian Ho
            <span class="block text-xs font-semibold tracking-wide opacity-80">Founder &amp; Licensed Electrician</span>
          </div>
          <span class="absolute -left-4 top-10 h-24 w-1.5 -skew-y-12 bg-brand-accent"></span>
        </div>

        <div class="reveal" style="transition-delay:120ms;">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> Meet Brian Ho
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.05] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Family-run, licensed &amp; <span class="text-brand-secondary">personally involved</span>
          </h2>
          <p class="mt-6 max-w-xl font-body text-lg font-medium leading-relaxed text-brand-secondary">
            Family-run, licensed, and personally involved in the jobs we take on across St Ives.
          </p>
          <p class="mt-4 max-w-xl font-body text-lg leading-relaxed text-brand-muted">
            I'm Brian Ho, and I founded Powerhub Electrical because St Ives deserves a trusted electrician who treats every property like their own. This page covers who we are, what drives us, and how you can verify our credentials before booking anything.
          </p>
        </div>
      </div>
    </section>

    <!-- PATH -->
    <section class="relative bg-brand-surface py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="reveal mb-4 max-w-2xl">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> The journey
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Brian's path into the <span class="text-brand-secondary">electrical trade</span>
          </h2>
        </div>
        <p class="reveal mb-12 max-w-2xl font-body text-lg leading-relaxed text-brand-muted">Here's a short timeline of how Powerhub Electrical came to be:</p>
        <div class="grid gap-5 lg:grid-cols-3">
          {path.map((p, i) => (
            <div class="reveal relative border border-white/8 bg-brand-bg p-7 transition-colors hover:border-brand-accent/40" style={`clip-path: polygon(0 0, 100% 0, 97% 100%, 0 100%); transition-delay:${i * 80}ms`}>
              <span class="font-heading text-4xl font-black tracking-[-0.03em] text-brand-secondary/30">{p.n}</span>
              <h3 class="mt-3 font-heading text-lg font-black uppercase tracking-[-0.01em] text-brand-text">{p.title}</h3>
              <p class="mt-2 font-body text-sm leading-relaxed text-brand-muted">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- DRIVES -->
    <section class="relative bg-brand-bg py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="reveal mb-4 max-w-2xl">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> What drives us
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            What drives Brian <span class="text-brand-secondary">and the team</span>
          </h2>
        </div>
        <p class="reveal mb-12 max-w-2xl font-body text-lg leading-relaxed text-brand-muted">A few principles guide every job across St Ives and beyond:</p>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {drives.map((d, i) => (
            <article class="reveal border border-white/8 bg-brand-surface p-6 transition-colors hover:border-brand-accent/50" style={`clip-path: polygon(0 0, 100% 0, 97% 100%, 0 100%); transition-delay:${i * 60}ms`}>
              <span class="mb-4 inline-flex h-9 w-9 items-center justify-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 85% 100%, 0 100%);">
                <Bolt class="h-5 w-5" />
              </span>
              <h3 class="font-heading text-lg font-black uppercase tracking-[-0.01em] text-brand-text">{d.title}</h3>
              <p class="mt-2 font-body text-sm leading-relaxed text-brand-muted">{d.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CREDENTIALS -->
    <section class="relative bg-brand-surface py-20 sm:py-28">
      <div class="mx-auto max-w-4xl px-5 sm:px-8">
        <div class="reveal mb-4">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> Verify us
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Licences, credentials &amp; <span class="text-brand-secondary">verification you can check</span>
          </h2>
        </div>
        <p class="reveal mb-8 font-body text-lg leading-relaxed text-brand-muted">Every credential behind Powerhub Electrical is a matter of public record:</p>
        <ul class="space-y-4">
          <li class="reveal flex items-start gap-3 border border-white/8 bg-brand-bg p-5" style="clip-path: polygon(0 0, 100% 0, 99% 100%, 0 100%);">
            <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0 100%);"><Bolt class="h-4 w-4" /></span>
            <span class="font-body text-base leading-relaxed text-brand-text">Electrical Contractor Licence #467291C, verifiable through the NSW Government <a href="https://verify.licence.nsw.gov.au/details/Contractor%20Licence/1-46C84T5" target="_blank" rel="noopener noreferrer" class="font-semibold text-brand-secondary underline decoration-brand-accent/50 underline-offset-4 hover:text-brand-accent">licence register</a></span>
          </li>
          <li class="reveal flex items-start gap-3 border border-white/8 bg-brand-bg p-5" style="clip-path: polygon(0 0, 100% 0, 99% 100%, 0 100%); transition-delay:60ms;">
            <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0 100%);"><Bolt class="h-4 w-4" /></span>
            <span class="font-body text-base leading-relaxed text-brand-text"><a href="https://abr.business.gov.au/ABN/View?id=91677354602" target="_blank" rel="noopener noreferrer" class="font-semibold text-brand-secondary underline decoration-brand-accent/50 underline-offset-4 hover:text-brand-accent">ABN 91 677 354 602</a>, searchable via the Australian Business Register</span>
          </li>
          <li class="reveal flex items-start gap-3 border border-white/8 bg-brand-bg p-5" style="clip-path: polygon(0 0, 100% 0, 99% 100%, 0 100%); transition-delay:120ms;">
            <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0 100%);"><Bolt class="h-4 w-4" /></span>
            <span class="font-body text-base leading-relaxed text-brand-text">Brian holds an Electrical Supervisor's Licence, gained through his apprenticeship and years on the tools</span>
          </li>
          <li class="reveal flex items-start gap-3 border border-white/8 bg-brand-bg p-5" style="clip-path: polygon(0 0, 100% 0, 99% 100%, 0 100%); transition-delay:180ms;">
            <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center bg-brand-accent/15 text-brand-accent" style="clip-path: polygon(0 0, 100% 0, 80% 100%, 0 100%);"><Bolt class="h-4 w-4" /></span>
            <span class="font-body text-base leading-relaxed text-brand-text">Connect with Brian directly on LinkedIn to see his professional background</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- LIFE OUTSIDE -->
    <section class="relative bg-brand-bg py-20 sm:py-28">
      <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-[1.15fr_0.85fr] lg:gap-16">
        <div class="reveal">
          <p class="mb-4 flex items-center gap-3 font-body text-xs font-semibold uppercase tracking-[0.3em] text-brand-muted">
            <span class="inline-block h-px w-10 bg-brand-accent"></span> Off the tools
          </p>
          <h2 class="font-heading text-3xl font-black uppercase leading-[1.02] tracking-[-0.01em] text-brand-text sm:text-4xl">
            Life outside <span class="text-brand-secondary">Powerhub Electrical</span>
          </h2>
          <p class="mt-6 max-w-xl font-body text-lg leading-relaxed text-brand-muted">
            Outside of work, you'll usually find me at the gym, at a local cafe, or down at the beach with my partner and our corgi. I'm part of a trades support network and a local BNI business networking group. If you're wondering about my coffee order, it's a 7/11 iced coffee with a double espresso and a dash of milk, most mornings around 7:30 am. When I get the chance, I like exploring the parks and bushland around Ku-ring-gai, which is one of the reasons St Ives is such a good place to work.
          </p>
        </div>
        <div class="reveal relative" style="transition-delay:120ms;">
          <div class="relative bg-brand-secondary/25 p-0.5 shadow-2xl shadow-black/60" style="clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%);">
            <div class="h-full w-full overflow-hidden" style="clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%);">
              <img src="/images/powerhub/services/Our-committment-to-success.webp" alt="Brian Ho of Powerhub Electrical around St Ives and Ku-ring-gai" class="h-full w-full object-cover" />
            </div>
          </div>
          <span class="absolute -bottom-4 -right-3 h-24 w-1.5 bg-brand-accent"></span>
        </div>
      </div>
    </section>

    <ServiceAreas />

    <!-- CTA -->
    <section class="relative overflow-hidden bg-brand-surface py-24">
      <div class="pointer-events-none absolute inset-0 opacity-[0.06]" style="background-image: linear-gradient(90deg, var(--color-brand-secondary) 1px, transparent 1px); background-size: 50px 50px;"></div>
      <div class="relative mx-auto max-w-4xl px-5 text-center sm:px-8">
        <p class="reveal mb-5 inline-flex items-center gap-2 border border-brand-accent/50 bg-brand-accent/10 px-4 py-1.5 font-heading text-xs font-bold uppercase tracking-widest text-brand-accent pulse-glow">
          <Bolt class="h-3.5 w-3.5" /> Talk to Brian first
        </p>
        <h2 class="reveal font-heading text-[clamp(2rem,5.5vw,3.4rem)] font-black uppercase leading-[1.0] tracking-[-0.01em] text-brand-text" style="transition-delay:80ms;">
          Want to meet the electrician <span class="text-brand-accent">before you book?</span>
        </h2>
        <p class="reveal mx-auto mt-6 max-w-2xl font-body text-lg leading-relaxed text-brand-muted" style="transition-delay:160ms;">
          Call Powerhub Electrical directly on {site.phoneDisplay} to talk through your job before booking, whether it's a quick question or a full quote. New customers save $50 on their first service, and every booking includes a free five-star safety inspection, with same-day appointments available across St Ives.
        </p>
        <div class="reveal mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row" style="transition-delay:240ms;">
          <a href={site.phoneHref} class="sweep-btn group relative inline-flex items-center justify-center gap-2 overflow-hidden px-8 py-4 font-heading text-base font-bold text-brand-bg" style="clip-path: polygon(6% 0, 100% 0, 94% 100%, 0 100%); background: var(--color-brand-accent);">
            <span class="relative z-10">Call {site.phoneDisplay}</span>
            <Bolt class="relative z-10 h-4 w-4" />
          </a>
          <OutlineButton href="/contact-us" class="px-8 py-4 text-base">Get a Free Quote</OutlineButton>
        </div>
      </div>
    </section>

    <Faqs heading="Frequently asked questions" items={aboutFaqs} bg="bg-brand-bg" />
  </main>
  <Footer />
</Layout>
